# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND ENVIRONMENT — LOCAL DEVELOPMENT
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# To switch to PRODUCTION, change VITE_API_URL               ← SWITCH
# ═══════════════════════════════════════════════════════════════════════════════

# Backend API URL
# Local:      http://localhost:8000
# Production: https://your-backend.onrender.com (or your hosted URL)
VITE_API_URL=http://localhost:8000                             # ← SWITCH
