# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT — LOCAL DEVELOPMENT
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# To switch to PRODUCTION, change the values marked with ← SWITCH
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment Mode ──────────────────────────────────────────────────────────
# Set to "local" or "production"                              ← SWITCH
APP_ENV=local

# ── URLs (switch these when deploying) ────────────────────────────────────────
# Local:      http://localhost:8000
# Production: https://your-backend.onrender.com (or your hosted URL)
BACKEND_URL=http://localhost:8000                              # ← SWITCH

# Local:      http://localhost:5173
# Production: https://your-app.netlify.app (or your hosted URL)
FRONTEND_URL=http://localhost:5173                             # ← SWITCH

# CORS — comma-separated frontend origins allowed to call the API
# Local:      http://localhost:5173,http://localhost:3000
# Production: https://your-app.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000     # ← SWITCH

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | gemini | ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Gemini (optional — only if LLM_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# Ollama (optional — only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,doc,docx

# ── SMTP Email (optional) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Blueprint Engine
SMTP_FROM_EMAIL=
